{
  "name": "driving-school-platform",
  "version": "1.0.0",
  "private": true,
  "description": "Monorepo for a production-ready driving school platform",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspace apps/web",
    "dev:api": "npm run dev --workspace apps/api",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "format": "npm run format --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace @drivingschool/db",
    "prisma:migrate": "npm run prisma:migrate --workspace @drivingschool/db",
    "prisma:seed": "npm run prisma:seed --workspace @drivingschool/db"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
